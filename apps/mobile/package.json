{
  "name": "winkly-mobile",
  "version": "1.0.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "validate-env": "node scripts/validate-env.js",
    "eas-build-pre-install": "node scripts/validate-env.js",
    "eas:sync-production-env": "node scripts/sync-eas-production-env.mjs",
    "eas:setup-ios-credentials": "eas credentials:configure-build -p ios -e preview",
    "start": "expo start",
    "start:clear": "expo start -c",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "test": "jest",
    "test:e2e": "maestro test -e EMAIL=qa@winkly.test -e PASSWORD=Test1234! .maestro/critical-path.yaml",
    "test:e2e:ios": "maestro test --device \"iPhone 16\" -e EMAIL=qa@winkly.test -e PASSWORD=Test1234! .maestro/critical-path.yaml",
    "test:e2e:android": "maestro test --device emulator-5554 -e EMAIL=qa@winkly.test -e PASSWORD=Test1234! .maestro/critical-path.yaml",
    "audit-i18n": "node scripts/audit-i18n.mjs",
    "audit-a11y": "node scripts/lint-a11y-touchables.mjs",
    "sync-i18n": "node scripts/sync-i18n-keys.mjs"
  },
