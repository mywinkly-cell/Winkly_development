# Winkly — STAGING environment
# Copy to: apps/mobile/.env.staging  (never commit the real file)
# Select it with: npm run env:staging  (from repo root), then `npm start`.
#
# Staging is a SEPARATE Supabase project from production. Test every new feature
# and migration here first. Staging data is disposable — never copy real user data in.

APP_ENV=staging

# Staging Supabase project orjccytcmklzcfjgqwwj (winkly-staging)
# Dashboard: https://supabase.com/dashboard/project/orjccytcmklzcfjgqwwj → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://orjccytcmklzcfjgqwwj.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_staging_supabase_anon_key

# Staging auth-redirect (Edge Function on the staging project)
EXPO_PUBLIC_AUTH_REDIRECT_URL=https://orjccytcmklzcfjgqwwj.supabase.co/functions/v1/auth-redirect

# Optional analytics — use a separate PostHog project/key for staging if you want telemetry here.
EXPO_PUBLIC_POSTHOG_API_KEY=
# EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# OAuth client IDs registered against the STAGING redirect URLs
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_FACEBOOK_APP_ID=

# EXPO_PUBLIC_EAS_PROJECT_ID=
