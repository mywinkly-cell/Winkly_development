# Winkly — CLOUD DEVELOPMENT environment (Winkly_development Supabase)
# Copy to: apps/mobile/.env.cloud-development  (never commit the real file)
#
# Use after local `supabase db reset` + `npm run supabase:push:development`.
# Points at the shared Winkly_development development project — NOT production.
# To activate: cp apps/mobile/.env.cloud-development apps/mobile/.env

APP_ENV=development

# Winkly_development gwgjdpqskusuejlwrsnd
# Dashboard: https://supabase.com/dashboard/project/gwgjdpqskusuejlwrsnd → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://gwgjdpqskusuejlwrsnd.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_development_supabase_anon_key

EXPO_PUBLIC_AUTH_REDIRECT_URL=https://gwgjdpqskusuejlwrsnd.supabase.co/functions/v1/auth-redirect

# Optional — use a separate PostHog project for dev cloud traffic
EXPO_PUBLIC_POSTHOG_API_KEY=

EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_FACEBOOK_APP_ID=
