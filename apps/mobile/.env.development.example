# Winkly — LOCAL DEVELOPMENT environment
# Copy to: apps/mobile/.env.development  (never commit the real file)
# Select it with: npm run env:dev   (from repo root), then `npm start`.
#
# This profile points at the LOCAL Supabase stack started with `supabase start`.
# Never point local dev at staging or production data.

APP_ENV=development

# Supabase local stack (from `supabase start` output → "API URL" and "anon key").
# Note: lib/supabase.ts rewrites 127.0.0.1/localhost → 10.0.2.2 on the Android emulator in DEV.
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_local_supabase_anon_key

# Optional: local auth-redirect Edge Function (served by `supabase start`)
EXPO_PUBLIC_AUTH_REDIRECT_URL=http://127.0.0.1:54321/functions/v1/auth-redirect

# Optional analytics — keep DISABLED locally so dev traffic never pollutes product analytics.
EXPO_PUBLIC_POSTHOG_API_KEY=
# EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Optional OAuth (usually unset locally)
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_FACEBOOK_APP_ID=

# Optional EAS project UUID (only needed for dev builds testing push)
# EXPO_PUBLIC_EAS_PROJECT_ID=
