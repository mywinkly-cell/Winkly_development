# Winkly – environment variables (copy this file to .env and fill in values)
# Do not commit .env. See docs/API_KEYS_AND_ENV.md for full reference.

# Required: Supabase project URL and anon key (from Dashboard → Project Settings → API)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional: Email verification redirect (Edge Function or Vercel). Add same URL to Supabase Auth → Redirect URLs.
EXPO_PUBLIC_AUTH_REDIRECT_URL=https://YOUR_PROJECT_REF.supabase.co/functions/v1/auth-redirect

# Optional: PostHog analytics (leave empty to disable)
EXPO_PUBLIC_POSTHOG_API_KEY=
# EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Optional: OAuth (Google Sign-In, Facebook Login)
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_FACEBOOK_APP_ID=

# Optional: Ably (future match/event pub/sub); leave empty to use Supabase Realtime only
# EXPO_PUBLIC_ABLY_KEY=
