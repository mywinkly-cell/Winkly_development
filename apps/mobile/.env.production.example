# Winkly — PRODUCTION environment
# Copy to: apps/mobile/.env.production  (never commit the real file)
#
# Production points at the LIVE Supabase project with real user data.
# Do NOT run experiments, manual data edits, or untested migrations here.
# For EAS/Play builds, prefer setting these as EAS environment variables (production)
# in the Expo dashboard rather than keeping a real .env.production on disk.

APP_ENV=production

# Production Supabase — WinklyApp (main) gwgjdpqskusuejlwrsnd
# Dashboard: https://supabase.com/dashboard/project/gwgjdpqskusuejlwrsnd → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://gwgjdpqskusuejlwrsnd.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_production_supabase_anon_key

EXPO_PUBLIC_AUTH_REDIRECT_URL=https://gwgjdpqskusuejlwrsnd.supabase.co/functions/v1/auth-redirect

# Production analytics
EXPO_PUBLIC_POSTHOG_API_KEY=
# EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Production OAuth client IDs
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_FACEBOOK_APP_ID=

# Real Expo/EAS project UUID for production push
# EXPO_PUBLIC_EAS_PROJECT_ID=
