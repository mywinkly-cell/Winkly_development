# Supabase Edge Functions — local secrets (copy to .env; never commit .env)
# Loaded automatically on `supabase start` and `supabase functions serve`.
# See docs/API_KEYS_AND_ENV.md. Push to cloud: `npx supabase secrets set --env-file .env`
#
# IMPORTANT: Put real keys only in supabase/functions/.env (git-ignored), NOT in this file.

# LLM providers (ai-gateway) — set at least one for plan/concierge/event_suggest
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Optional Anthropic model overrides (Premium routing — see docs/API_KEYS_AND_ENV.md):
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_MODEL_LITE=claude-3-5-haiku-20241022
# ANTHROPIC_MODEL_PLAN=claude-sonnet-4-20250514

# Rate limiting + AI response cache (ai-gateway; recommended for production)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Production CORS (ai-gateway, delete-account) — comma-separated origins; unset = localhost dev defaults
# CORS_ALLOWED_ORIGINS=https://orjccytcmklzcfjgqwwj.supabase.co

# Push (notify-fanout, pending-plan-confirm, expo-push-notify) — Expo account access token
# EXPO_ACCESS_TOKEN=

# notify-fanout webhook auth — must match private.webhook_config.secret in the DB
# WEBHOOK_SECRET=

# auth-redirect CSRF signing (min 16 chars; required for prod HTTPS redirect)
# AUTH_REDIRECT_STATE_SECRET=

# Optional: external events (get-nearby-external-events)
# MEETUP_API_KEY=
# EVENTBRITE_PRIVATE_TOKEN=

# Optional: Google Places grounding (ai-gateway, weather-pivot-cron)
# GOOGLE_PLACES_API_KEY=
# GOOGLE_MAPS_API_KEY=
